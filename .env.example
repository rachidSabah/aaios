# AAiOS environment variables — copy to .env and edit
# ====================================================
#
# This file is the example for the OPTIONAL Docker Compose deployment.
# For the Windows-native deployment, config lives in
# %ProgramData%\AAiOS\config\config.yaml (see config/defaults.yaml).
#
# NEVER commit the real .env file. Add your real values locally only.

# --- Core ---
AAiOS_ENV=production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AAiOS_SECRET_KEY=change-me-to-a-32-byte-random-string

# --- Database ---
POSTGRES_PASSWORD=change-me
AAiOS_DB_URL=postgresql+asyncpg://aaios:change-me@postgres:5432/aaios

# --- Vector DB ---
AAiOS_QDRANT_URL=http://qdrant:6333

# --- Redis (optional, for multi-process) ---
AAiOS_REDIS_URL=redis://redis:6379/0

# --- LLM providers (each is optional — system runs in degraded mode without) ---
# Add real keys via the dashboard or `aaios config set-secret <name> <value>`.
# These env vars are an alternative way to provide keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
NVIDIA_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
MISTRAL_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# Local providers (no key required)
OLLAMA_URL=http://localhost:11434
LM_STUDIO_URL=http://localhost:1234/v1

# --- OAuth (optional; if unset, local mode is used) ---
AAiOS_OAUTH_GITHUB_CLIENT_ID=
AAiOS_OAUTH_GITHUB_CLIENT_SECRET=

# --- Telemetry (optional) ---
AAiOS_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Egress (comma-separated allow-list) ---
AAiOS_EGRESS_ALLOWED_HOSTS=api.openai.com,api.anthropic.com,github.com
