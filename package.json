  "license": "Apache-2.0",
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @aaios/web dev",
